# Tu espacio — copiar a .env (no subir a Git)

# Servidor
FLASK_DEBUG=0
FLASK_PORT=5000
FLASK_HOST=0.0.0.0

# URLs externas (opcional)
# TU_ESPACIO_INTRANET_URL=
# TU_ESPACIO_AULA_URL=

# Rate limiting (opcional)
# RATE_LIMIT_DAY=200
# RATE_LIMIT_HOUR=50

# Seguridad
# SECRET_KEY=tu-clave-secreta-aqui

# AI/ML Configuration
AI_PROVIDER=openai  # openai, anthropic, local
# AI_API_KEY=tu-api-key-aqui
AI_MODEL=gpt-3.5-turbo
AI_MAX_TOKENS=500
AI_TEMPERATURE=0.7

# Comandos locales (Windows)
# Habilitar integración con sistema
CYBER_LOCAL_COMMANDS=1
