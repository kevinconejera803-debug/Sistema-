{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "python",
      "request": "launch",
      "name": "Backend Flask",
      "program": "${workspaceFolder}/backend/run.py",
      "cwd": "${workspaceFolder}/backend"
    },
    {
      "type": "chrome",
      "request": "launch",
      "name": "Frontend Vite",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}/frontend"
    }
  ]
}
